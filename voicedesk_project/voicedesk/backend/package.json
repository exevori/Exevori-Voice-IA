    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "fastify": "^4.28.0",
    "gpt-tokenizer": "^3.4.0",
    "helmet": "^7.1.0",
    "html-to-text": "^10.0.0",
    "imap-simple": "^5.1.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.11",
